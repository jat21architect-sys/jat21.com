# ---------------------------------------------------------------------------
# .dockerignore — keeps the build context small and clean.
# Excludes files that are not needed inside the container or that should
# not be copied there (secrets, runtime artefacts, tooling state).
# ---------------------------------------------------------------------------

# Version control
.git
.gitignore

# Local virtualenvs — dependencies are installed inside the image
.venv
venv
env

# Python byte-code and caches
__pycache__
*.py[cod]
*.pyo
*.pyd
*.so

# Test/tool caches
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov

# Local SQLite database — not needed in the build context and should not be
# baked into the image (even for dev; it is mounted via the volume at runtime)
db.sqlite3

# Collected static files and local media uploads
staticfiles/
media/

# Editor / OS junk
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Secrets — always exclude; provided via env_file at runtime
.env

# Node / frontend tooling (if added later)
node_modules

# Docker files themselves (avoid recursive context)
Dockerfile
compose.yml
docker-compose.yml
